# Host ports for the stack (defaults shown). Change here to avoid clashes.
FRONTEND_PORT=5173
API_PORT=3000
EXTERNAL_API_PORT=4000
DB_PORT=5432

# Postgres credentials (used by the api + postgres containers)
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nestjs_db

# Local browser origin allowed to call the API. Use comma-separated origins for
# multiple frontend hosts.
CORS_ORIGIN=http://localhost:5173

# Sync / external API behavior
SYNC_CRON_ENABLED=true
SYNC_INTERVAL_MS=60000
EXTERNAL_API_TIMEOUT_MS=5000
EXTERNAL_API_RETRY_ATTEMPTS=3
EXTERNAL_API_RETRY_BASE_DELAY_MS=100

# Browser polling behavior
VITE_API_POLL_INTERVAL_MS=5000
