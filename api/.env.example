# Postgres connection (matches docker-compose.yml).
# Use localhost when running the app locally against the dockerized DB.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nestjs_db

# External API / sync behavior
EXTERNAL_API_URL=http://localhost:4000
EXTERNAL_API_TIMEOUT_MS=5000
EXTERNAL_API_RETRY_ATTEMPTS=3
EXTERNAL_API_RETRY_BASE_DELAY_MS=100
SYNC_CRON_ENABLED=true
